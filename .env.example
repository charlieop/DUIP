# --------------------------------------------------------------------------
# DUIP environment variables.
#
# Copy this file to `.env` (which is gitignored) and fill in your secrets.
# `modal_app.py` loads `.env` automatically via python-dotenv before the
# Modal client authenticates, so you can run `modal run modal_app.py::...`
# without having to `modal setup` separately.
# --------------------------------------------------------------------------

# ---- Modal credentials ---------------------------------------------------
# Create a token at https://modal.com/settings/tokens (or run `modal token new`
# locally and copy the values from `~/.modal.toml`).
MODAL_TOKEN_ID=ak-xxxxxxxxxxxxxxxxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxxxxxxxxxxxxxxxx

# ---- Weights & Biases ----------------------------------------------------
# Get your key at https://wandb.ai/authorize. Set this even when training
# remotely on Modal — `modal_app.py` forwards it to the container as a
# Modal Secret so the run streams to your W&B dashboard.
WANDB_API_KEY=

# ---- Hugging Face Hub (optional) -----------------------------------------
# Only needed if the Qwen3.5-2B checkpoint is gated on your account, or if
# you hit rate limits on anonymous downloads. Get one at
# https://huggingface.co/settings/tokens.
HF_TOKEN=
