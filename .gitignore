# ---------------------------------------------------------------------------
# Project artifacts (data, model weights, training outputs)
#
# These are huge (multi-GB) and reproducible from the pipeline:
#   data/raw/         <- HF cache + slim reviews/meta parquet
#   data/processed/   <- sessionized train/val/test jsonl + items.json
#   checkpoints/      <- trained .pt weights
#   results/          <- eval metrics + training history
#   logs/             <- per-run text logs from get_logger()
# ---------------------------------------------------------------------------
data/
checkpoints/
results/
logs/

# Hugging Face / transformers / datasets caches if they ever land in-repo
.cache/
*.parquet
*.arrow

# ---------------------------------------------------------------------------
# Model weight files (in case any land outside checkpoints/)
# ---------------------------------------------------------------------------
*.pt
*.pth
*.bin
*.safetensors
*.ckpt
*.onnx

